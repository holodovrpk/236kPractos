<Page x:Class="_236kPractos.TicketsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:_236kPractos"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="TicketsPage">

    <StackPanel>
        <TextBlock Text="Билеты" FontSize="24" />

        <DataGrid x:Name="TicketGrid" AutoGenerateColumns="False" Height="150"
              SelectionChanged="TicketGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Номер билета" Width="200"
                                Binding="{Binding TicketId}"/>
                <DataGridTextColumn Header="Фильм" Width="150" 
                                Binding="{Binding Film.Name}"/>
                <DataGridTextColumn Header="Дата сеанса" Width="140" 
                                Binding="{Binding date}"/>
                <DataGridTextColumn Header="Цена" Width="120" 
                                Binding="{Binding Price}"/>

            </DataGrid.Columns>
        </DataGrid>


        <StackPanel Orientation="Horizontal">
            <StackPanel Margin="5" Width="300">
                <TextBlock Text="Номер билета"/>
                <TextBox Text="{Binding Ticket}" IsReadOnly="True"/>
                
                <TextBlock Text="Фильм"/>
                
                <ComboBox x:Name="BoxFilms"
                        DisplayMemberPath="Name"
                        SelectedValuePath="FilmId"
                        SelectedValue="{Binding FilmId}" />


                <TextBlock Text="Зал"/>
                <ComboBox x:Name="BoxHall"
                        DisplayMemberPath="Name"
                        SelectedValuePath="HallId"
                        SelectedValue="{Binding HallId}" />
                
                <TextBlock Text="Цена"/>
                <TextBox Text="{Binding Price}"/>
            </StackPanel>

            <StackPanel  Margin="5" Width="300">
                <TextBlock Text="Дата сеанса"/>
                <TextBox Text="{Binding date}"/>
                <TextBlock Text="Ряд"/>
                <TextBox Text="{Binding Row}"/>
                <TextBlock Text="Место" />
                <TextBox Text="{Binding Place}"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="10">
            <Button Content="🗑️ Удалить" Click="Del_Click" Margin="7" Width="150" Height="20" Background="Bisque"/>
            <Button Content="➕ Продать"  Margin="7" Width="150" Height="20" Background="Bisque" Click="Sell_Click"/>
            <Button Content="💾 Сохранить изменения" Click="Save_Click" Margin="7" Width="150" Height="20" Background="Bisque"/>
        </StackPanel>

    </StackPanel>
</Page>
