<Page x:Class="_236kPractos.FilmsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:_236kPractos"
      mc:Ignorable="d" 
      d:DesignHeight="550" d:DesignWidth="800"
      Title="FilmsPage">

    <StackPanel>
        <StackPanel Orientation="Horizontal" >
            <TextBlock Text="Фильмы" FontSize="24" Width="350"/>
            <TextBlock Text="🔍 Поиск" VerticalAlignment="Center" FontSize="14"/>
            <TextBox x:Name="txtFind" Width="200" Margin="5"/>
        </StackPanel>
    <DataGrid x:Name="FilmGrid" AutoGenerateColumns="False" Height="150"
                  SelectionChanged="FilmGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название" Width="200"
                                    Binding="{Binding Name}"/>
                <DataGridTextColumn Header="Режисер" Width="150" 
                                    Binding="{Binding Rejiser}"/>
                <DataGridTextColumn Header="Год выпуска" Width="140" 
                                    Binding="{Binding Year}"/>
                <DataGridTextColumn Header="Жанр" Width="120" 
                                    Binding="{Binding Genre}"/>

            </DataGrid.Columns>
        </DataGrid>


        <StackPanel Orientation="Horizontal">
            <StackPanel Margin="5" Width="300">
                <TextBlock Text="Название фильма"/>
                <TextBox Text="{Binding Name}"/>
                <TextBlock Text="Режисер"/>
                <TextBox Text="{Binding Rejiser}"/>
                <TextBlock Text="Длительность, мин"/>
                <TextBox Text="{Binding Duration}"/>
                <TextBlock Text="Год выпуска"/>
                <TextBox Text="{Binding Year}"/>
            </StackPanel>

            <StackPanel  Margin="5" Width="300">
                <TextBlock Text="Жанр"/>
                <TextBox Text="{Binding Genre}"/>
                <TextBlock Text="Страна"/>
                <TextBox Text="{Binding Country}"/>
                <TextBlock Text="Описание" />
                <TextBox Text="{Binding Description}" Height="50" TextWrapping="Wrap"/>
            </StackPanel>
        </StackPanel>
        
        <StackPanel Orientation="Horizontal" Margin="10">
            <Button Content="🗑️ Удалить" Click="Del_Click" Margin="7" Width="150" Height="20" Background="Bisque"/>
            <Button Content="➕ Добавить" Click="Add_Click" Margin="7" Width="150" Height="20" Background="Bisque"/>
            <Button Content="💾 Сохранить изменения" Click="Save_Click" Margin="7" Width="150" Height="20" Background="Bisque"/>
        </StackPanel>
        
    </StackPanel>
</Page>
