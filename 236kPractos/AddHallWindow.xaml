<Window x:Class="_236kPractos.AddHallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_236kPractos"
        mc:Ignorable="d"
        Title="AddHallWindow" Height="250" Width="350">
    <StackPanel Width="300">
        <TextBlock Text="Название зала" />
        <TextBox Text="{Binding Name}" />
        <TextBlock Text="Количество рядов" />
        <TextBox Text="{Binding Rows}" />
        <TextBlock Text="Количество мест" />
        <TextBox Text="{Binding Places}" />
        <Button Content="💾 Сохранить" Margin="10" Click="Save_Click"/>
        <Button Content="❌ Отмена" Margin="10" Click="Cancel_Click"/>
    </StackPanel>
</Window>
