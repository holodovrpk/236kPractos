<Window x:Class="_236kPractos.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_236kPractos"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Orientation="Horizontal" Background="Bisque"
                    Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2">
            <TextBlock Text="Кинотеатр ТРЭШ" Margin="5" FontSize="34" FontWeight="ExtraBold"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Grid.Column="0" Background="Bisque">
            <Button Content="Фильмы" Width="150" Height="30" Margin="7" Background="Bisque" Click="Film_Click"/>
            <Button Content="Залы" Width="150" Height="30" Margin="7" Background="Bisque" Click="Hall_Click"/>
            <Button Content="Билеты" Width="150" Height="30" Margin="7" Background="Bisque" Click="Ticket_Click"/>
            <Button Content="Выход" Width="150" Height="30" Margin="7" Background="Bisque"/>
        </StackPanel>

        <Frame x:Name="MainFraim" NavigationUIVisibility="Hidden" Grid.Row="1" Grid.Column="1"/>

    </Grid>
</Window>
